# ============================================================
# MarrowStack Environment Variables
# Copy this file to .env.local and fill in all values
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── NextAuth ──────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# ── GitHub OAuth (for login) ──────────────────────────────────
# Create at: https://github.com/settings/developers → New OAuth App
# Homepage URL: https://yourdomain.com
# Callback URL: https://yourdomain.com/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# ── Google OAuth (optional — for auth block Google provider) ──
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── GitHub PAT (for granting repo access to buyers) ───────────
# Create at: https://github.com/settings/tokens → Generate new (classic)
# Required scopes: repo (Full control of private repositories)
GITHUB_PAT=ghp_your_personal_access_token
# Your GitHub username or org that owns the block repos
GITHUB_OWNER=your_github_username

# ── PayPal (India-compatible) ─────────────────────────────────
# Sign up at: https://developer.paypal.com
# Create app → get Sandbox credentials first
# IMPORTANT for India: Use USD as transaction currency
# PayPal supports INR display but USD for actual transactions
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
# After creating webhook at: PayPal Dev → Webhooks → Add webhook
# URL: https://yourdomain.com/api/webhooks/paypal
# Events: CHECKOUT.ORDER.APPROVED, PAYMENT.CAPTURE.COMPLETED, PAYMENT.CAPTURE.REFUNDED
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
# Pro subscription plan IDs (create in PayPal dashboard or via API)
PAYPAL_PRO_MONTHLY_PLAN_ID=P-your_monthly_plan_id
PAYPAL_PRO_YEARLY_PLAN_ID=P-your_yearly_plan_id

# ── Resend (email) ────────────────────────────────────────────
# Sign up at: https://resend.com → API Keys
# Add your domain for production (free tier allows resend.dev subdomain)
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=MarrowStack <noreply@yourdomain.com>

# ── Anthropic Claude (AI customization feature) ───────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_OWNER=your_github_username
